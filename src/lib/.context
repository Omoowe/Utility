## Core Files

### tools.ts - Central Source of Truth

```typescript
interface Tool {
  slug: string;                    // URL: /calculators/mortgage-calculator
  name: string;                    // Display name
  category: Category;              // Category tag
  description: string;             // Card description
  keywords: string[];              // SEO keywords

  // SEO metadata
  title: string;                   // <title> tag
  metaDescription: string;         // Meta description
  h1: string;                       // H1 heading

  // Content references
  intro: string;                   // Short intro (100-150 words)
  howItWorks: string;              // How it works (markdown)
  interpretationGuide: string;     // How to interpret results

  // Relations
  relatedTools: string[];          // Slugs of related tools
  category: Category;

  // Calculator schema
  calculator: CalculatorConfig;    // Inputs, outputs, compute function

  // SEO schema
  schema: SchemaMarkup;            // Auto-generated FAQPage + Calculator
}

export const TOOLS: Record<string, Tool> = {
  'mortgage-calculator': {
    slug: 'mortgage-calculator',
    name: 'Mortgage Calculator',
    category: 'finance',
    title: 'Mortgage Calculator | Calculate Monthly Payment',
    metaDescription: 'Free mortgage calculator. Estimate your monthly payment...',
    h1: 'Mortgage Payment Calculator',
    description: 'Calculate monthly mortgage payment based on loan amount, interest rate, and term.',
    keywords: ['mortgage calculator', 'monthly payment', 'loan calculator'],
    intro: 'Unsure about your monthly mortgage payment...',
    howItWorks: 'The mortgage formula is...',
    relatedTools: ['loan-calculator', 'paycheck-calculator'],
    calculator: {
      inputs: [
        { name: 'principal', label: 'Loan Amount', type: 'currency', validation: { min: 1 } },
        { name: 'rate', label: 'Annual Interest Rate (%)', type: 'number', validation: { min: 0, max: 20 } },
        { name: 'years', label: 'Loan Term (Years)', type: 'number', validation: { min: 1, max: 50 } },
      ],
      compute: calculateMortgage,
      outputs: [
        { name: 'payment', label: 'Monthly Payment', format: 'currency' },
        { name: 'totalPayment', label: 'Total Payment', format: 'currency' },
        { name: 'totalInterest', label: 'Total Interest', format: 'currency' },
      ],
    },
  },
  // ... more tools
};
```

**Functions:**
```typescript
export function getToolBySlug(slug: string): Tool {
  const tool = TOOLS[slug];
  if (!tool) throw new Error(`Tool not found: ${slug}`);
  return tool;
}

export function getAllTools(): Tool[] {
  return Object.values(TOOLS);
}

export function getToolsByCategory(category: Category): Tool[] {
  return Object.values(TOOLS).filter((tool) => tool.category === category);
}

export function getCategories(): Category[] {
  const categories = new Set(Object.values(TOOLS).map((tool) => tool.category));
  return Array.from(categories);
}
```

### Calculation Functions

**File:** `calculators/mortgage.ts`

Pure functions that compute results. No side effects.

```typescript
export interface MortgageInputs {
  principal: number;  // Loan amount ($)
  rate: number;       // Annual interest rate (%)
  years: number;      // Loan term (years)
}

export interface MortgageOutput {
  monthlyPayment: number;
  totalPayment: number;
  totalInterest: number;
}

export function calculateMortgage(inputs: MortgageInputs): MortgageOutput {
  const { principal, rate, years } = inputs;

  // Validate inputs
  if (principal <= 0) throw new Error('Principal must be positive');
  if (rate < 0) throw new Error('Rate cannot be negative');
  if (years <= 0) throw new Error('Years must be positive');

  // Convert to monthly values
  const monthlyRate = rate / 100 / 12;
  const numPayments = years * 12;

  // PMT formula: M = P * [r(1+r)^n] / [(1+r)^n - 1]
  if (monthlyRate === 0) {
    // If no interest, just divide principal by # payments
    const monthlyPayment = principal / numPayments;
    return {
      monthlyPayment,
      totalPayment: principal,
      totalInterest: 0,
    };
  }

  const monthlyPayment =
    (principal * (monthlyRate * Math.pow(1 + monthlyRate, numPayments))) /
    (Math.pow(1 + monthlyRate, numPayments) - 1);

  const totalPayment = monthlyPayment * numPayments;
  const totalInterest = totalPayment - principal;

  return {
    monthlyPayment,
    totalPayment,
    totalInterest,
  };
}
```

**Key principles:**
- Pure functions (no side effects)
- Explicit types (inputs, outputs)
- Error handling (validate inputs)
- Tested (unit tests, Phase 2+)
- Well-commented (formulas, edge cases)

### Utilities

**File:** `utils/formatting.ts`

```typescript
export function formatCurrency(amount: number, decimals = 2): string {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: decimals,
    maximumFractionDigits: decimals,
  }).format(amount);
}

export function formatNumber(value: number, decimals = 2): string {
  return value.toLocaleString('en-US', {
    minimumFractionDigits: decimals,
    maximumFractionDigits: decimals,
  });
}

export function formatPercentage(value: number, decimals = 2): string {
  return `${value.toFixed(decimals)}%`;
}
```

**File:** `utils/validation.ts`

```typescript
export function validateNumber(value: any, min?: number, max?: number): { valid: boolean; error?: string } {
  if (typeof value !== 'number' || isNaN(value)) {
    return { valid: false, error: 'Must be a number' };
  }
  if (min !== undefined && value < min) {
    return { valid: false, error: `Must be at least ${min}` };
  }
  if (max !== undefined && value > max) {
    return { valid: false, error: `Must be at most ${max}` };
  }
  return { valid: true };
}
```

**File:** `utils/seo.ts`

```typescript
export function generateCalculatorSchema(tool: Tool): object {
  return {
    '@context': 'https://schema.org',
    '@type': 'Calculator',
    name: tool.name,
    description: tool.metaDescription,
    url: `https://toolnest.com/calculators/${tool.slug}`,
    inputType: tool.calculator.inputs.map((input) => input.type),
    inputLabel: tool.calculator.inputs.map((input) => input.label),
    outputType: tool.calculator.outputs[0].format,
    outputLabel: tool.calculator.outputs[0].label,
  };
}

export function generateFAQSchema(faqs: FAQ[]): object {
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  };
}
```

